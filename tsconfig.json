{
  "compilerOptions": {
    "target": "es2018",
    "module": "commonjs",
    "lib": ["es2018", "dom"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./build",
    "rootDir": ".",
    "types": ["jest", "node"],
    "typeRoots": ["./node_modules/@types"],
    "resolveJsonModule": true
  },
    "include": [
        "type script/**/*",
        "test/**/*"
      ]
  ],
  "exclude": [
    "node_modules",
    "build"
  ]
}